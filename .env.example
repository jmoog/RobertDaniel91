# ─────────────────────────────────────────────────────────────────────
# Variables d'environnement — Robert Daniel Couverture
# Copier en « .env » pour le dev local. En production : Coolify.
# Le formulaire de devis envoie les emails via Brevo (route /api/devis).
# ─────────────────────────────────────────────────────────────────────

# ── Brevo (envoi des emails de devis) ─────────────────────────────────
# Clé API Brevo : https://app.brevo.com/settings/keys/api  (commence par xkeysib-)
BREVO_API_KEY=xkeysib-...

# ── Expéditeur ────────────────────────────────────────────────────────
# Doit être un domaine VÉRIFIÉ sur Brevo (DKIM/DMARC validés).
FROM_EMAIL=contact@robert-daniel-couverture.fr
FROM_NAME=Robert Daniel Couverture

# ── Destinataires des notifications (séparés par des virgules) ────────
ADMIN_EMAILS=jmoog27@gmail.com,robert.entreprise@outlook.fr

# ── Anti-robot Cloudflare Turnstile (optionnel) ───────────────────────
# Clé de SITE (publique) — exposée au navigateur, à définir en BUILD-TIME.
PUBLIC_TURNSTILE_SITE_KEY=
# Clé SECRÈTE — vérification serveur, à définir en RUNTIME (jamais exposée).
# Si absente, la vérification Turnstile est ignorée (le site fonctionne quand même).
TURNSTILE_SECRET_KEY=
