---
// Header double barre :
// 1. barre cuivre — telephone + WhatsApp + liens institutionnels (desktop)
// 2. barre claire — logo (centre sur mobile) + menu services
const wa = 'https://wa.me/33683961518';
---
<header class="entete">
  <div class="entete__topbar">
    <div class="conteneur entete__topbar-int">
      <div class="entete__topbar-contacts">
        <a href="tel:0683961518" class="entete__tel">
          <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 1H8C6.34 1 5 2.34 5 4v16c0 1.66 1.34 3 3 3h8c1.66 0 3-1.34 3-3V4c0-1.66-1.34-3-3-3zm-2 20h-4v-1h4v1zm3.25-3H6.75V4h10.5v14z"/></svg>
          06 83 96 15 18
        </a>
        <a href={wa} class="entete__wa" target="_blank" rel="noopener noreferrer">
          <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.2-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.5-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2z"/></svg>
          WhatsApp
        </a>
      </div>
      <nav aria-label="Navigation secondaire">
        <ul class="entete__liens">
          <li><a href="/">Accueil</a></li>
          <li><a href="/a-propos/">À propos</a></li>
          <li><a href="/devis-gratuit/">Devis gratuit</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <div class="entete__principal">
    <div class="conteneur entete__principal-int">
      <a href="/" class="entete__marque" aria-label="Robert Daniel Couverture — retour a l'accueil">
        <img
          src="/logo-robert-daniel-artisan-couvreur-91.webp"
          alt="Robert Daniel Couverture — couvreur a Étréchy (91)"
          class="entete__logo"
          width="240"
          height="120"
          decoding="async"
        />
      </a>

      <nav class="entete__nav" aria-label="Navigation principale">
        <button class="entete__burger" type="button" aria-expanded="false" aria-controls="menu-principal">
          <span class="visuallyhidden">Menu</span>
          <svg class="icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        </button>
        <ul id="menu-principal" class="entete__menu">
          <li class="entete__menu-mobile"><a href="/">Accueil</a></li>
          <li class="entete__menu-mobile"><a href="/a-propos/">À propos</a></li>
          <li><a href="/renovation-toiture/">Rénovation</a></li>
          <li><a href="/reparation-toiture/">Réparation</a></li>
          <li><a href="/nettoyage-toiture/">Nettoyage</a></li>
          <li><a href="/charpente/">Charpente</a></li>
          <li><a href="/zinguerie/">Zinguerie</a></li>
          <li class="entete__menu-extra"><a href="/isolation-toiture/">Isolation de toiture</a></li>
          <li class="entete__menu-extra"><a href="/fenetre-de-toit-velux/">Fenêtre de toit Velux</a></li>
          <li class="entete__menu-extra"><a href="/ramonage-cheminee/">Ramonage</a></li>
          <li class="entete__menu-extra"><a href="/inspection-toiture-drone/">Inspection par drone</a></li>
          <li class="entete__menu-mobile entete__menu-devis"><a href="/devis-gratuit/">Demander un devis gratuit &rarr;</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .entete {
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: var(--ombre);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .entete--cachee { transform: translateY(-100%); }

  .entete__topbar { background: var(--cuivre); }
  .entete__topbar-int {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.55rem;
  }
  .entete__topbar-contacts { display: flex; align-items: center; gap: 0.7rem; }
  .entete__tel, .entete__wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 0.45em 1em;
    border-radius: var(--rayon);
    white-space: nowrap;
  }
  .entete__tel { background: var(--blanc); color: var(--bleu); }
  .entete__tel:hover { color: var(--cuivre-fonce); }
  .entete__wa { background: #25D366; color: var(--blanc); }
  .entete__wa:hover { background: #1ebe5b; color: var(--blanc); }
  .entete__tel .icone, .entete__wa .icone { width: 1.1rem; height: 1.1rem; }

  .entete__liens {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .entete__liens a {
    color: var(--blanc);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
  }
  .entete__liens a:hover { text-decoration: underline; color: var(--blanc); }

  .entete__principal { background: #e5f1f9; }
  .entete__principal-int {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.4rem;
  }
  .entete__marque {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .entete__logo {
    display: block;
    width: auto;
    height: 60px;
    transition: opacity var(--transition);
  }
  .entete__marque:hover .entete__logo { opacity: 0.85; }

  .entete__menu {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .entete__menu a {
    text-decoration: none;
    color: var(--bleu);
    font-weight: 600;
    font-size: 0.98rem;
    transition: color var(--transition);
  }
  .entete__menu a:hover { color: var(--cuivre); }
  /* Élements affichés uniquement sur mobile */
  .entete__menu-mobile, .entete__menu-extra { display: none; }

  .entete__burger {
    display: none;
    background: none;
    border: none;
    color: var(--bleu);
    padding: 0.4rem;
    cursor: pointer;
  }
  .entete__burger .icone { width: 1.9rem; height: 1.9rem; }

  @media (max-width: 1080px) {
    .entete__liens { display: none; }
    .entete__topbar-int { justify-content: center; }
  }

  @media (max-width: 800px) {
    .entete__topbar { display: none; }
    .entete__logo { height: 50px; }

    /* Logo centré, burger à droite */
    .entete__principal-int { position: relative; justify-content: center; }
    .entete__burger {
      display: block;
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
    }

    .entete__menu {
      display: none;
      position: absolute;
      inset-inline: 0;
      top: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--blanc);
      box-shadow: var(--ombre-forte);
      padding: 0.3rem 1.1rem 1rem;
      max-height: calc(100vh - 64px);
      overflow-y: auto;
    }
    .entete__menu.ouvert { display: flex; }

    .entete__menu-mobile, .entete__menu-extra { display: block; }
    .entete__menu li { border-bottom: 1px solid var(--gris-100); }
    .entete__menu a { display: block; padding: 0.9em 0.2em; font-size: 1.02rem; }

    /* Lien devis mis en avant en bas du menu */
    .entete__menu-devis { border-bottom: none !important; margin-top: 0.5rem; }
    .entete__menu-devis a {
      background: var(--cuivre);
      color: var(--blanc);
      text-align: center;
      border-radius: var(--rayon);
      padding: 0.85em 1em;
      font-weight: 700;
    }
    .entete__menu-devis a:hover { color: var(--blanc); }
  }
</style>

<script>
  const burger = document.querySelector('.entete__burger');
  const menu = document.getElementById('menu-principal');
  const setMenu = (ouvert) => {
    menu?.classList.toggle('ouvert', ouvert);
    burger?.setAttribute('aria-expanded', String(Boolean(ouvert)));
    document.body.classList.toggle('menu-ouvert', Boolean(ouvert));
  };
  burger?.addEventListener('click', () => setMenu(!menu?.classList.contains('ouvert')));
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));

  const entete = document.querySelector('.entete');
  const mobile = window.matchMedia('(max-width: 800px)');
  let tick = false;
  window.addEventListener('scroll', () => {
    if (tick) return;
    tick = true;
    requestAnimationFrame(() => {
      const cacher = mobile.matches && window.scrollY > 900 && !menu?.classList.contains('ouvert');
      entete?.classList.toggle('entete--cachee', Boolean(cacher));
      tick = false;
    });
  }, { passive: true });
</script>
