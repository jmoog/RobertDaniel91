---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';
import CookieBanner from '../components/CookieBanner.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  extraSchemas?: object[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/logo-robert-daniel-couverture.png',
  extraSchemas = [],
} = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="RZ91L_09GryLedIG7CbNh3i1aDNpvRKLSQLN3C7A_44" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-V457V2WS4D" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-V457V2WS4D');
    </script>

    <link rel="icon" href="/favicon.png?v=3" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />

    <link rel="preload" href="/fonts/lexend-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/red-hat-display-400.woff2" as="font" type="font/woff2" crossorigin />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Robert Daniel Couverture — Artisan couvreur dans l'Essonne" />

    <!-- Donnees structurees RoofingContractor -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "RoofingContractor",
      "@id": "https://robert-daniel-couverture.fr/#localbusiness",
      "name": "Robert Daniel Couverture",
      "legalName": "SAS MR ROBERT",
      "alternateName": ["Robert Daniel", "MR ROBERT", "Couvreur Étréchy", "Couvreur Essonne Robert Daniel"],
      "description": description,
      "image": "https://robert-daniel-couverture.fr/images/logo-robert-daniel-couverture.png",
      "logo": { "@type": "ImageObject", "url": "https://robert-daniel-couverture.fr/images/logo-robert-daniel-couverture.png", "caption": "Logo Robert Daniel Couverture — Artisan couvreur dans l'Essonne" },
      "url": "https://robert-daniel-couverture.fr",
      "telephone": "+33683961518",
      "email": "robert.entreprise@outlook.fr",
      "founder": { "@type": "Person", "name": "Robert Daniel", "jobTitle": "Président" },
      "priceRange": "€€",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Espèces, Chèque, Virement bancaire",
      "taxID": "FR69937889236",
      "isicV4": "4391",
      "naics": "238160",
      "address": { "@type": "PostalAddress", "streetAddress": "42 Grande Rue", "postalCode": "91580", "addressLocality": "Étréchy", "addressRegion": "Île-de-France", "addressCountry": "FR" },
      "areaServed": { "@type": "AdministrativeArea", "name": "Essonne (91) — Étréchy et communes environnantes" },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"], "opens": "08:00", "closes": "20:00" }
      ],
      "hasOfferCatalog": { "@type": "OfferCatalog", "name": "Services de couverture", "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rénovation de toiture" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Remplacement de toiture" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Réparation de toiture" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Nettoyage et démoussage de toiture" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Charpente" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Isolation de toiture" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pose de fenêtres de toit Velux" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Zinguerie et gouttières" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Inspection de toiture par drone" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ramonage de cheminée" } }
      ]},
      "knowsAbout": ["Couverture", "Zinguerie", "Charpente", "Rénovation de toiture", "Remplacement de toiture", "Réparation de toiture", "Nettoyage de toiture", "Isolation de toiture", "Pose de fenêtres de toit Velux", "Inspection de toiture par drone", "Ramonage de cheminée", "Gouttières"]
    })} />

    {extraSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingContact />
    <CookieBanner />
  </body>
</html>
