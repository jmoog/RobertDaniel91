---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilAriane from '../components/FilAriane.astro';
import CtaDevis from '../components/CtaDevis.astro';
import services from '../data/services.json';
import villes from '../data/villes.json';

const title = 'Couvreur a Cerny (91590) - Robert Daniel Couverture - Devis Gratuit';
const description = "Couvreur a Cerny : renovation, reparation, nettoyage de toiture, charpente, zinguerie. Robert Daniel Couverture, artisan couvreur dans l'Essonne. Devis gratuit.";

const autresVilles = villes.filter((v) => v.slug !== 'couvreur-cerny');

const extraSchemas = [{
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Couvreur a Cerny',
  serviceType: 'Travaux de couverture',
  provider: { '@id': 'https://robert-daniel-couverture.fr/#localbusiness' },
  areaServed: { '@type': 'City', name: 'Cerny' },
  url: 'https://robert-daniel-couverture.fr/couvreur-cerny/',
  description,
}];
---
<BaseLayout title={title} description={description} extraSchemas={extraSchemas}>
  <section class="hero">
    <div class="conteneur">
      <FilAriane items={[{ label: 'Accueil', href: '/' }, { label: 'Couvreur a Cerny' }]} />
    </div>
    <div class="conteneur hero__grille">
      <div class="hero__texte">
        <p class="hero__badge"><span class="hero__point" aria-hidden="true"></span> Intervention a Cerny</p>
        <h1>Couvreur a Cerny (91590)</h1>
        <p class="hero__accroche">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
          tempor incididunt ut labore et dolore magna aliqua. Robert Daniel Couverture
          intervient a Cerny et dans toute l'Essonne.
        </p>
        <ul>
          <li><strong>Lorem ipsum</strong> dolor sit amet consectetur.</li>
          <li><strong>Garantie décennale</strong> sur tous nos travaux.</li>
          <li><strong>Devis gratuit</strong> et sans engagement.</li>
        </ul>
        <div class="hero__actions">
          <a href="tel:0683961518" class="btn btn--cuivre">
            <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 1H8C6.34 1 5 2.34 5 4v16c0 1.66 1.34 3 3 3h8c1.66 0 3-1.34 3-3V4c0-1.66-1.34-3-3-3zm-2 20h-4v-1h4v1zm3.25-3H6.75V4h10.5v14z"/></svg>
            06 83 96 15 18
          </a>
          <a href="/devis-gratuit/" class="btn btn--bleu">Devis Gratuit &rarr;</a>
        </div>
      </div>
      <div class="hero__media">
        <div class="placeholder-img hero__photo">Photo toiture Cerny</div>
        <div class="carte hero__garantie">
          <p><strong>Garantie Décennale</strong><br />Pour tous travaux de couverture</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--bleute">
    <div class="conteneur">
      <span class="surtitre">Nos prestations a Cerny</span>
      <h2>Services de couverture a Cerny</h2>
      <div class="grille-services">
        {services.map((s) => (
          <a href={s.slug === 'zinguerie' ? '/zinguerie/' : `/${s.slug}/`} class="carte carte-service">
            <div class="carte-service__img">{s.alt}</div>
            <div class="carte-service__corps">
              <h3>{s.label}</h3>
              <p>{s.accroche}</p>
              <span class="carte-service__lien">{s.lien} &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="conteneur duo">
      <div class="placeholder-img">Photo chantier toiture Cerny</div>
      <div class="prose">
        <h2>Lorem ipsum dolor sit amet</h2>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
        <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.</p>
      </div>
    </div>
  </section>

  <CtaDevis />

  <section class="section section--gris">
    <div class="conteneur">
      <h2>Nous intervenons aussi dans ces communes</h2>
      <ul class="nuage-villes">
        {autresVilles.map((v) => (
          <li><a href={`/${v.slug}/`}>{v.nom}</a></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
