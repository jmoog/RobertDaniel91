---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilAriane from '../../components/FilAriane.astro';
import CtaDevis from '../../components/CtaDevis.astro';
import villes from '../../data/villes.json';

const title = "Zinguerie dans l'Essonne (91) - Robert Daniel Couverture";
const description = "Travaux de zinguerie à Étréchy et dans l'Essonne : gouttieres zinc, aluminium, PVC, descentes, noues, solins, couvertines. Devis gratuit.";

const sousPages = [
  { slug: 'gouttieres-zinc', label: 'Gouttieres zinc' },
  { slug: 'gouttieres-aluminium', label: 'Gouttieres aluminium' },
  { slug: 'gouttieres-pvc', label: 'Gouttieres PVC' },
  { slug: 'descentes-eaux-pluviales', label: 'Descentes eaux pluviales' },
  { slug: 'noues-aretiers', label: 'Noues et aretiers' },
  { slug: 'solins-raccords', label: 'Solins et raccords' },
  { slug: 'couvertines', label: 'Couvertines' },
];

const extraSchemas = [{
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Zinguerie',
  serviceType: 'Zinguerie',
  provider: { '@id': 'https://robert-daniel-couverture.fr/#localbusiness' },
  areaServed: { '@type': 'AdministrativeArea', name: 'Essonne (91)' },
  url: 'https://robert-daniel-couverture.fr/zinguerie/',
  description,
}];
---
<BaseLayout title={title} description={description} extraSchemas={extraSchemas}>
  <section class="hero">
    <div class="conteneur">
      <FilAriane items={[{ label: 'Accueil', href: '/' }, { label: 'Zinguerie' }]} />
    </div>
    <div class="conteneur hero__grille">
      <div class="hero__texte">
        <p class="hero__badge"><span class="hero__point" aria-hidden="true"></span> Gouttieres, descentes, noues, solins</p>
        <h1>Zinguerie dans l'Essonne</h1>
        <p class="hero__accroche">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        <ul>
          <li><strong>Lorem ipsum</strong> dolor sit amet.</li>
          <li><strong>Consectetur</strong> adipiscing elit.</li>
          <li><strong>Garantie décennale</strong> sur tous nos travaux.</li>
        </ul>
        <div class="hero__actions">
          <a href="tel:0683961518" class="btn btn--cuivre">
            <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 1H8C6.34 1 5 2.34 5 4v16c0 1.66 1.34 3 3 3h8c1.66 0 3-1.34 3-3V4c0-1.66-1.34-3-3-3zm-2 20h-4v-1h4v1zm3.25-3H6.75V4h10.5v14z"/></svg>
            06 83 96 15 18
          </a>
          <a href="/devis-gratuit/" class="btn btn--bleu">Devis Gratuit &rarr;</a>
        </div>
      </div>
      <div class="hero__media">
        <div class="placeholder-img hero__photo">Photo zinguerie Essonne</div>
        <div class="carte hero__garantie">
          <p><strong>Garantie Décennale</strong><br />Pour tous travaux de couverture</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sous-pages cocon zinguerie -->
  <section class="section">
    <div class="conteneur">
      <span class="surtitre">Nos prestations de zinguerie</span>
      <h2>Tous nos services de zinguerie</h2>
      <div class="grille-services">
        {sousPages.map((sp) => (
          <a href={`/zinguerie/${sp.slug}/`} class="carte carte-service">
            <div class="carte-service__img">{sp.label}</div>
            <div class="carte-service__corps">
              <h3>{sp.label}</h3>
              <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor.</p>
              <span class="carte-service__lien">En savoir plus &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--bleute">
    <div class="conteneur duo">
      <div class="placeholder-img">Photo travaux zinguerie</div>
      <div class="prose">
        <h2>Lorem ipsum dolor sit amet</h2>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.</p>
        <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.</p>
      </div>
    </div>
  </section>

  <CtaDevis />

  <section class="section section--gris">
    <div class="conteneur">
      <h2>Zinguerie — nos communes</h2>
      <ul class="nuage-villes">
        {villes.map((v) => (
          <li><a href={`/${v.slug}/`}>{v.nom}</a></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
